# FalconBroom environment sample
# Copy this to `.env` and fill in secrets before running locally or for partners.
# DO NOT commit `.env` to source control.

# App
APP_ENV=development
APP_URL=http://127.0.0.1:3009
PORT=3009
LOG_LEVEL=INFO

# JWT settings (used for session/invite tokens)
# Use a strong, unguessable secret in production.
JWT_SECRET=replace_with_a_secure_random_value
JWT_ALGO=HS256

# Data encryption / session encryption keys
# Used by the app to encrypt persisted session or sensitive data.
DATA_ENC_KEY=replace_with_base64_or_hex_key
SESSION_ENCRYPTION_KEY=replace_with_base64_or_hex_key

# Database (optional). Example: sqlite or postgres
# DATABASE_URL=sqlite:///./db.sqlite3
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (optional, used by Celery/queues)
REDIS_URL=redis://localhost:6379/0

# SMTP (for sending invites / verification emails).
# If left empty the app will write email payloads to data/emails/ as a fallback.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=you@example.com

# Optional observability / error tracking
SENTRY_DSN=

# Feature flags / runtime toggles
# When set to "1" the custom single-process runner will skip lifespan handling.
# Use only for local debugging.
LIFESPAN_OFF=0

# Admin / test accounts (examples for partners)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=changeme
