# Ignore runtime data and generated artifacts
data/*
!data/.gitignore

# Virtualenvs
.venv/
venv/

# Node
node_modules/
frontend/node_modules/

# Build outputs
frontend/dist/
frontend/build/
src-tauri/target/

# Python cache
__pycache__/
*.pyc

# Secrets and env
.env
.env.*
!.env.sample

# Editor/IDE
.vscode/
.idea/
*.swp
.DS_Store

# Logs, DBs
*.log
*.sqlite
*.db

# Local debug artifacts
run_uvicorn*.log
run_uvicorn_deepdebug.log
scripts/*.txt
scripts/py_spy_*
# Keep tests and source tracked
!/tests/
 
# Ignore large sanitized output; allow synthetic demo folder
samples/sanitized/
!samples/demo_custom/
